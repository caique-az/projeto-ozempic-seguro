# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Database
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
src/data/*.db
src/ozempic_seguro/data/*.db*
data/*.db*

# Encryption keys
*.key
encryption.key
secret.key

# Logs
*.log
logs/
src/logs/
src/ozempic_seguro/logs/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# mypy
.mypy_cache/
.dmypy.json

# setuptools-scm generated version file
src/ozempic_seguro/_version.py

# Pyre type checker
.pyre/

# VS Code
.vscode/

# JetBrains IDEs (PyCharm, IntelliJ, etc.)
.idea/

# Claude Code internal files
.claude/

# MacOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Images and PDFs (if not tracked)
*.png
*.jpg
*.jpeg
*.pdf

# Ignore PDF and images in root, but not in src/assets
!/src/assets/*.png
!/src/assets/*.jpg
!/src/assets/*.jpeg
!/src/assets/*.pdf 
# Temporary test files
tests/test_database.py.bak
temp/
tmp/
